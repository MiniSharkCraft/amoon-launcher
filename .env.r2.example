# Copy file này thành .env.r2 rồi điền vào
# .env.r2 đã được gitignore rồi, đừng commit lên

# Lấy trong Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here

R2_ACCOUNT_ID=your_account_id
R2_BUCKET=your_bucket
R2_PUBLIC_URL=your_domain
